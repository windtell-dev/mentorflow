# DigitalOcean Gradient AI — create a model access key in the console:
# Inference › Serverless Inference › Create a Model Access Key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
# Optional overrides
DIGITAL_OCEAN_MODEL=openai-gpt-5.5
DIGITAL_OCEAN_MODEL_FAST=openai-gpt-5.4-mini
DIGITAL_OCEAN_MODEL_TTS=fal-ai/elevenlabs/tts/multilingual-v2
PORT=3001
